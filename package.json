    "lint": "ng lint",
    "github-build": "ng build --project dev --base-href https://pranxy.github.io/zordon-ui/",
    "github-deploy": "npx angular-cli-ghpages --dir=dist/dev --no-silent"
  },
  "private": true,
  "dependencies": {
