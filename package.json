{
  "name": "zordon-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build dev",
    "build:lib": "ng build components --configuration production",
    "watch": "ng build --watch --configuration development",
